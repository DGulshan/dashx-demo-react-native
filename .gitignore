# OSX
#
.DS_Store

# Xcode
#
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate
ios/.xcode.env.local

# Signing & provisioning — never commit these, they carry developer-specific
# credentials / private keys.
*.p12
*.cer
*.pem
*.mobileprovision
*.provisionprofile

# Android/IntelliJ
#
build/
.idea
.gradle
# Kotlin 2.x incremental-compile cache (errors/, sessions/). Per-dev,
# regenerated on every compile.
.kotlin/
# Android NDK / CMake build cache — per-dev, 80+MB per architecture,
# regenerated on every native build. Only present when a RN dep pulls in
# native C++ code (e.g. react-native-safe-area-context).
.cxx/
local.properties
*.iml
*.hprof

# node.js
#
node_modules/
npm-debug.log
yarn-error.log
coverage/

# Env
#
.env
.env.local
.env.*.local

# Firebase project configs — each contributor drops in their own. These
# files aren't cryptographically sensitive (per Firebase docs, the web
# apiKey is a public identifier), but committing them would pin the demo
# to one maintainer's Firebase project and auto-register every fork's
# push tokens there.
ios/DashXDemoRN/GoogleService-Info.plist
android/app/google-services.json

# BUCK
buck-out/
\.buckd/
*.keystore
!debug.keystore

# fastlane
#
# It is recommended to not store the screenshots in the git repo. Instead, use fastlane to re-generate the
# screenshots whenever they are needed.
# For more information about the recommended setup visit:
# https://docs.fastlane.tools/best-practices/source-control/

**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# Bundle artifact
*.jsbundle

# Ruby / CocoaPods
/ios/Pods/
/vendor/bundle/

# VSCode
.vscode/
